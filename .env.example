# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string.
# DATABASE_URL  = the *pooled* connection (port 6543, pgbouncer) used at runtime.
# DIRECT_URL    = the *direct* connection (port 5432) used by `prisma db push`.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Local dev without Supabase: any Postgres works, e.g.
# DATABASE_URL="postgresql://plansaloon@localhost:54330/plansaloon"
# DIRECT_URL="postgresql://plansaloon@localhost:54330/plansaloon"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Seed owner login (defaults: owner@actionplan.sa / changeme — CHANGE IN PROD)
# ADMIN_EMAIL="owner@actionplan.sa"
# ADMIN_PASSWORD=""

# ── Site ─────────────────────────────────────────────────────────────────────
# Absolute base URL used in confirmation emails for the manage-booking link.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Email (optional) ─────────────────────────────────────────────────────────
# Set to activate booking-confirmation emails via Resend.
# RESEND_API_KEY=""
# RESEND_FROM="Action Plan <bookings@actionplan.sa>"
