DATABASE_URL="file:./dev.db"

# Auth.js — generate a real secret with: openssl rand -base64 32
AUTH_SECRET=""

# Seeded owner admin account (used by prisma/seed.ts)
ADMIN_EMAIL="owner@actionplan.sa"
ADMIN_PASSWORD="changeme"

# Optional: set to enable real email confirmations via Resend.
# When empty, the notify() pipeline logs to the console instead.
RESEND_API_KEY=""
RESEND_FROM="Action Plan Barbershop <bookings@actionplan.sa>"
